{
  "name": "@jbrowse/plugin-lorax",
  "version": "0.1.0",
  "description": "JBrowse 2 Lorax ARG visualization plugin using deck.gl",
  "keywords": [
    "jbrowse",
    "jbrowse2",
    "lorax",
    "arg",
    "deckgl",
    "webgl"
  ],
  "license": "Apache-2.0",
  "homepage": "https://jbrowse.org",
  "bugs": "https://github.com/GMOD/jbrowse-components/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/jbrowse-components.git",
    "directory": "plugins/lorax"
  },
  "author": "JBrowse Team",
  "distMain": "dist/index.js",
  "srcMain": "src/index.ts",
  "main": "src/index.ts",
  "files": [
    "dist",
    "esm"
  ],
  "scripts": {
    "build": "npm-run-all build:*",
    "test": "cd ../..; jest --passWithNoTests plugins/lorax",
    "prepublishOnly": "yarn test",
    "prepack": "yarn build && yarn useDist",
    "postpack": "yarn useSrc",
    "useDist": "node ../../scripts/useDist.js",
    "useSrc": "node ../../scripts/useSrc.js",
    "prebuild": "yarn clean",
    "build:esm": "tsc -p tsconfig.build.esm.json",
    "build:commonjs": "tsc -p tsconfig.build.commonjs.json",
    "clean": "rimraf dist esm *.tsbuildinfo"
  },
  "dependencies": {
    "@lorax/core": "file:../../../../../packages/core",
    "@deck.gl/core": "^9.3.1",
    "@deck.gl/layers": "^9.3.1",
    "@deck.gl/react": "^9.3.1",
    "@deck.gl/widgets": "^9.3.1",
    "apache-arrow": "^18.1.0",
    "@jbrowse/core": "^3.7.0",
    "@jbrowse/mobx-state-tree": "^5.4.7",
    "@jbrowse/plugin-linear-genome-view": "^3.7.0",
    "@luma.gl/core": "^9.3.1",
    "@luma.gl/webgl": "^9.3.1",
    "axios": "^1.6.0",
    "mobx": "^6.0.0",
    "mobx-react": "^9.0.0",
    "rxjs": "^7.0.0",
    "socket.io-client": "^4.7.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "distModule": "esm/index.js",
  "srcModule": "src/index.ts",
  "module": "",
  "publishConfig": {
    "access": "public"
  }
}
